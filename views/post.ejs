<%- include('partials/head', { title: post.title, post }) %>
<%- include('partials/navbar') %>

<main class="post-container">

    <!-- Title -->
    <h1 class="text-3xl font-bold"><%= post.title %></h1>

    <!-- Metadata -->
 <div class="post-meta">
  <span class="category-badge"><%= post.category %></span>

  <p>
    By <span class="font-medium"><%= post.author || 'Vincent Leintoi' %></span>
  </p>

  <p class="text-sm text-gray-600 dark:text-gray-400">
    Published on 
    <time datetime="<%= new Date(post.date).toLocaleDateString() %>">
      <%= post.formattedDate %>
    </time>
    • 
    <%= Math.ceil(((post.content || '').replace(/<[^>]+>/g, '').split(/\s+/).length || 0) / 200) %> min read
  </p>
</div>

    <!-- Featured Image -->
    <% if (post.media) { %>
      <figure class="my-8">
        <img src="<%= post.media %>" alt="<%= post.title %>" class="post-image">
        <% if (post.caption || post.photoCredit) { %>
          <figcaption class="image caption text-sm text-gray-500 dark:text-gray-400 mt-2">
            <%= post.caption || '' %>
            <% if (post.photoCredit) { %><br>
              <br><span class="photo-credit italic text-gray-500"><%= post.photoCredit %></span>
            <% } %>
          </figcaption>
        <% } %>
      </figure>
    <% } %>

    <!-- YouTube Video -->
    <% if (post.videoUrl) { %>
      <div class="video-wrapper my-6">
        <iframe src="<%= post.videoUrl %>" frameborder="0" allowfullscreen class="w-full h-64 md:h-96"></iframe>
      </div>
    <% } %>

    <!-- content -->
<article class="post-content" id="articleContent">
  <%- post.content %>
</article>

    <!-- 📚 Related Posts -->
  <% if (relatedPosts && relatedPosts.length > 0) { %>
    <section class="mt-16 border-t pt-10 max-w-4xl">
      <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">Related Posts📑</h2>
      <div class="grid gap-6">
        <% relatedPosts.forEach(rp => { %>
          <a href="/post/<%= rp.slug %>" class="block rounded-[16px] overflow-hidden shadow-md hover:shadow-xl bg-white dark:bg-gray-800 transition duration-300">
            <div class="flex justify-center">
              <% if (rp.media) { %>
                <img src="<%= rp.media %>" alt="<%= rp.title %>" class="rounded-[16px] object-cover" style="width:300px; height:200px;" />
              <% } else { %>
                <div class="bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 italic rounded-[16px]" style="width:300px; height:200px;">
                  No image
                </div>
              <% } %>
            </div>
            <div class="p-4">
              <h3 class="text-lg font-semibold mb-1 text-gray-800 dark:text-white"><%= rp.title %></h3>
              <p class="text-sm text-gray-600 dark:text-gray-300"><%= rp.content.replace(/<[^>]+>/g, '').slice(0, 100) %>...</p>
              <div class="mt-2 text-xs text-gray-400"><%= new Date(rp.date).toLocaleDateString() %> • <%= rp.category %></div>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

    <!-- Comments Section -->
    <section id="comments" class="comments-section">
    <h2 class="section-heading">💬 Comments</h2>

    <% if (comments && comments.length > 0) { %>
      <% comments.forEach(comment => { %>
        <div class="comment">
          <div class="comment-header">
            <span class="comment-author"><%= comment.author %></span>
            <% if (comment.flagged) { %>
              <span class="flagged">🚩 Flagged</span>
            <% } %>
          </div>
          <div class="comment-text" id="comment-<%= comment._id %>"></div>

          <script>
            const rawComment_<%= comment._id %> = `<%- comment.text ? comment.text.replace(/`/g, '\\`') : '' %>`;
            document.addEventListener('DOMContentLoaded', () => {
              const target = document.getElementById('comment-<%= comment._id %>');
              if (target) {
                target.innerHTML = DOMPurify.sanitize(marked.parse(rawComment_<%= comment._id %>));
              }
            });
          </script>
         
          <div class="upvote-section">
            <button class="upvote-btn" data-post-slug="<%= post.slug %>" data-comment-id="<%= comment._id %>">⬆ Upvote</button>
            <span><%= comment.upvotes || 0 %> upvote<%= (comment.upvotes === 1 ? '' : 's') %></span>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="no-comments">No comments yet. Be the first to share your thoughts!</p>
    <% } %>

    <!-- ✏️ Add Comment Form -->
    <form action="/post/<%= post.slug %>/comment" method="POST" class="comment-form">
      <div class="form-group">
        <label for="author">👤 Your Name</label>
        <input type="text" name="author" id="author" required placeholder="e.g. VinceRadio">
      </div>
      <div class="form-group">
        <label for="wysiwyg">💬 Your Comment</label>
        <textarea name="text" id="wysiwyg" required placeholder="Write in **Markdown**..." rows="5"></textarea>
      </div>
      <button type="submit" class="submit-btn">Add Comment🆕</button>
    </form>

    <!-- 🔎 Live Markdown Preview -->
    <div class="preview-box">
      <h3>🔎 Live Preview</h3>
      <div id="commentPreview" class="comment-preview"></div>
    </div>

    <!-- 📤 Share Buttons -->
    <div class="mt-16 border-t border-gray-200 dark:border-gray-700 pt-12">
      <h3 class="text-lg font-semibold mb-3 text-gray-800 dark:text-gray-100">Share this post</h3>
      <div class="flex flex-wrap gap-6 text-2xl share-buttons">
        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(requestUrl) %>" target="_blank" class="hover:text-blue-600"><i class="fab fa-facebook"></i></a>
        <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(requestUrl) %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" class="hover:text-gray-700 dark:hover:text-gray-300"><i class="fab fa-x-twitter"></i></a>
        <a href="https://wa.me/?text=<%= encodeURIComponent(post.title + ' ' + requestUrl) %>" target="_blank" class="hover:text-green-500"><i class="fab fa-whatsapp"></i></a>
        <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent(requestUrl) %>&title=<%= encodeURIComponent(post.title) %>" target="_blank" class="hover:text-blue-700"><i class="fab fa-linkedin"></i></a>
        <a href="https://t.me/share/url?url=<%= encodeURIComponent(requestUrl) %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" class="hover:text-sky-500"><i class="fab fa-telegram"></i></a>
        <a href="https://reddit.com/submit?url=<%= encodeURIComponent(requestUrl) %>&title=<%= encodeURIComponent(post.title) %>" target="_blank" class="hover:text-orange-600"><i class="fab fa-reddit"></i></a>
        <a href="mailto:?subject=<%= encodeURIComponent(post.title) %>&body=<%= encodeURIComponent(requestUrl) %>" class="hover:text-gray-600 dark:hover:text-gray-400"><i class="fas fa-envelope"></i></a>
      </div>
    </div>

  </section>

  <!-- Sidebar -->
  <aside class="space-y-6">
    <%- include('partials/sidebar') %>
  </aside>

</main>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.5/dist/purify.min.js"></script>
<script>
  // Live Markdown preview for comments
  const input = document.getElementById('wysiwyg');
  const preview = document.getElementById('commentPreview');

  input?.addEventListener('input', () => {
    preview.innerHTML = DOMPurify.sanitize(marked.parse(input.value));
  });

  // Comment upvotes
  document.querySelectorAll('.upvote-btn').forEach(button => {
    button.addEventListener('click', async () => {
      const postSlug = button.dataset.postSlug;
      const commentId = button.dataset.commentId;

      try {
        const res = await fetch(`/post/${postSlug}/comment/${commentId}/upvote`, {
          method: 'POST'
        });

        const data = await res.json();

        if (data.success) {
          button.nextElementSibling.textContent =
            `${data.upvotes} upvote${data.upvotes === 1 ? '' : 's'}`;
        }

      } catch (err) {
        console.error('Upvote failed:', err);
      }
    });
  });
</script>
 <script>
document.addEventListener("DOMContentLoaded", () => {

  const article = document.getElementById("articleContent");
  if (!article) return;

  const paragraphs = article.querySelectorAll("p");

  // Do not show ads if article is too short
  if (paragraphs.length < 4) return;

  // Decide spacing dynamically
  let interval = 3;

  if (paragraphs.length > 12) interval = 4;
  if (paragraphs.length > 20) interval = 5;

  paragraphs.forEach((p, index) => {

    if ((index + 1) % interval === 0) {

      const adContainer = document.createElement("div");
      adContainer.style.margin = "30px 0";
      adContainer.style.textAlign = "center";

      const ad = document.createElement("ins");

      ad.className = "adsbygoogle";
      ad.style.display = "block";

      ad.setAttribute("data-ad-client", "ca-pub-5130727817078688");
      ad.setAttribute("data-ad-slot", "1234567890");
      ad.setAttribute("data-ad-format", "fluid");
      ad.setAttribute("data-ad-layout", "in-article");

      adContainer.appendChild(ad);

      p.after(adContainer);

      (adsbygoogle = window.adsbygoogle || []).push({});
    }

  });

});
</script>
