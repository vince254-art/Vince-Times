<section class="hero-section" style="background-image: url('<%= posts[0].media || "/images/hero-bg.jpg" %>');">
  <div class="hero-content">
    <h1 class="hero-title"><%= posts[0].title || "Welcome to Vince Times" %></h1>
    <a href="#latest" class="hero-button">Explore Latest Stories</a>
  </div>
</section>

<style>
  .hero-section {
    padding: 6rem 2rem;
    text-align: center;
    background: linear-gradient(rgba(108, 111, 118, 0.879), rgb(48, 48, 48)), 
                url('/images/hero-bg.jpg') center/cover no-repeat;
    color: #fff;
    background-size: cover;
    background-position: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    animation: fadeInUp 1s ease-out forwards;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-button {
    background-color: #2563eb;
    color: #fff;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>
